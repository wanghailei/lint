{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"formatter": {
		"indentStyle": "tab",
		"indentWidth": 1,
		"lineWidth": 9999
	},
	"javascript": {
		"formatter": {
			"indentStyle": "tab"
		}
	},
	"css": {
		"formatter": {
			"indentStyle": "tab"
		}
	}
}
