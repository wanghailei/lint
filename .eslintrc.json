{
	"env": {
		"browser": true,
		"es2024": true,
		"node": true
	},
	"parserOptions": {
		"ecmaVersion": "latest",
		"sourceType": "module"
	},
	"rules": {
		"indent": ["error", "tab"],
		"quotes": ["error", "double"],
		"semi": ["error", "never"],
		"no-unused-vars": "warn",
		"no-console": "warn",
		"eqeqeq": "error",
		"curly": "error",
		"no-var": "error",
		"prefer-const": "warn",
		"no-eval": "error",
		"no-implied-eval": "error"
	}
}
